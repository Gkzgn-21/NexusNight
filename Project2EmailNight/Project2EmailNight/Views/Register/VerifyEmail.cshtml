@model Project2EmailNight.Dtos.VerifyEmailDto
@{
    Layout = null;
}

<link href="~/lib/bootstrap/dist/css/bootstrap.min.css" rel="stylesheet" />

<style>
    body {
        margin: 0;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: url('/images/giris.png') no-repeat center center fixed;
        background-size: cover;
        font-family: Arial, sans-serif;
    }

    .card-box {
        width: 950px;
        max-width: 95%;
        border-radius: 18px;
        overflow: hidden;
        box-shadow: 0 20px 60px rgba(0,0,0,.35);
        background: rgba(255,255,255,.92);
        display: flex;
    }

    .left {
        flex: 1;
        padding: 40px;
        background: rgba(255,255,255,.95);
    }

    .right {
        width: 420px;
        background: #e9e8ff;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 42px;
        font-weight: 800;
        color: #111;
    }
</style>

<div class="card-box">
    @if (TempData["MailError"] != null)
    {
        <div class="alert alert-danger">
            @TempData["MailError"]
        </div>
    }

    <div class="left">
        <h2 class="fw-bold mb-2">E-Postanızı Doğrulayın</h2>
        <p class="text-muted mb-3">Mailinize gelen 6 haneli kodu girerek hesabını aktifleştir.</p>

        @if (TempData["MailError"] != null)
        {
            <div class="alert alert-warning">@TempData["MailError"]</div>
        }
        @if (TempData["Ok"] != null)
        {
            <div class="alert alert-success">@TempData["Ok"]</div>
        }

        <div asp-validation-summary="All" class="text-danger mb-3"></div>

        @if (TempData["Warn"] != null)
        {
            <div class="alert alert-warning">@TempData["Warn"]</div>
        }
        @if (TempData["Ok"] != null)
        {
            <div class="alert alert-success">@TempData["Ok"]</div>
        }

        @if (TempData["MailError"] != null)
        {
            <div class="alert alert-danger">
                <b>Mail gönderme hatası:</b> @TempData["MailError"]
            </div>
        }

        <form asp-action="VerifyEmail" asp-controller="Register" method="post">
            <div class="mb-2">
                <a class="btn btn-outline-secondary"
                   asp-controller="Register"
                   asp-action="ResendCode"
                   asp-route-email="@Model.Email">
                    Kodu tekrar gönder
                </a>
            </div>

            <div class="mb-3">
                <label class="form-label">E-Posta</label>
                @if (!string.IsNullOrWhiteSpace(Model?.Email))
                {
                    <input asp-for="Email" class="form-control" readonly />
                }
                else
                {
                    <input asp-for="Email" class="form-control" placeholder="ornek@gmail.com" />
                }
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label class="form-label">Doğrulama Kodu</label>
                <input asp-for="Code" class="form-control" maxlength="6" placeholder="6 haneli kod" />
                <span asp-validation-for="Code" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-warning px-4">Maili Doğrula</button>
            <a class="btn btn-link" href="/Login/UserLogin">Giriş sayfasına dön</a>
        </form>
    </div>

    <div class="right">
        NexusNight
    </div>
</div>

<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>