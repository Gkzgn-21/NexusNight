@model Project2EmailNight.Models.DashboardViewModel
@{
    Layout = null;
}
<!doctype html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>NexusNight</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <style>
        html, body {
            height: 100%;
        }

        body {
            margin: 0;
            background: url('/images/giris.png') center/cover no-repeat fixed;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .overlay {
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,.55);
        }

        .cardx {
            position: relative;
            width: min(920px, 92vw);
            border-radius: 18px;
            background: rgba(255,255,255,.10);
            border: 1px solid rgba(255,255,255,.18);
            backdrop-filter: blur(10px);
            color: #fff;
            padding: 28px;
        }

        .brand {
            font-weight: 800;
            font-size: 44px;
            letter-spacing: .5px;
            margin-bottom: 10px;
        }

        .actions {
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
            margin-top: 18px;
        }

        .btnx {
            border-radius: 14px;
            padding: 12px 18px;
            font-weight: 700;
        }
    </style>
</head>
<body>
    <div class="overlay"></div>

    <div class="cardx text-center">
        <div class="brand">NexusNight</div>

        <div class="actions justify-content-center">
            <a class="btn btn-warning btnx" href="/Login/UserLogin">Giriş Yap</a>
            <a class="btn btn-light btnx" href="/Register/Index">Kayıt Ol</a>
        </div>
    </div>
</body>
</html>

