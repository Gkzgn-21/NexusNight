@model Project2EmailNight.Dtos.UserLoginDto
@{
    Layout = null;
}

<!doctype html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Giriş Yap - NexusNight</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <style>
        html, body {
            height: 100%;
        }

        body {
            margin: 0;
            background: url('/images/giris.png') center/cover no-repeat fixed;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .overlay {
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,.55);
        }

        .cardx {
            position: relative;
            width: min(760px, 92vw);
            background: #fff;
            border-radius: 16px;
            box-shadow: 0 30px 80px rgba(0,0,0,.45);
            padding: 28px;
        }

        .title {
            font-weight: 800;
            font-size: 26px;
            margin-bottom: 10px;
        }

        .muted {
            color: #6b7280;
            margin-bottom: 14px;
        }
    </style>
</head>
<body>
    <div class="overlay"></div>

    <div class="cardx">
        <div class="title">Giriş Yap</div>
        <div class="muted">Email doğrulaması yapılmış hesap ile giriş yapabilirsiniz.</div>

        @if (TempData["ok"] != null)
        {
            <div class="alert alert-success">@TempData["ok"]</div>
        }

        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label class="form-label">Kullanıcı Adı</label>
                <input class="form-control" asp-for="Username" />
            </div>

            <div class="mb-3">
                <label class="form-label">Şifre</label>
                <input class="form-control" asp-for="Password" type="password" />
            </div>

            <div class="d-flex gap-2">
                <button class="btn btn-warning px-4">Giriş Yap</button>
                <a class="btn btn-outline-secondary" href="/Register/Index">Kayıt Ol</a>
                <a class="btn btn-outline-dark ms-auto" href="/">Ana Sayfa</a>
            </div>
        </form>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>