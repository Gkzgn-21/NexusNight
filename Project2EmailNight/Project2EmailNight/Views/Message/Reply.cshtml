@model Project2EmailNight.Models.ReplyViewModel

@{
    ViewData["Title"] = "Yanıtla";
}

<h2>Yanıtla</h2>

<form asp-action="Reply" method="post">
    <input type="hidden" asp-for="OriginalMessageId" />

    <div class="form-group">
        <label>Alıcı</label>
        <input class="form-control" asp-for="ToEmail" readonly />
    </div>

    <div class="form-group">
        <label>Konu</label>
        <input class="form-control" asp-for="Subject" />
    </div>

    <div class="form-group">
        <label>Mesaj</label>
        <textarea class="form-control" asp-for="Body" rows="8"></textarea>
    </div>

    <button type="submit" class="btn btn-primary">Gönder</button>
    <a class="btn btn-secondary" asp-action="MessageDetail" asp-route-id="@Model.OriginalMessageId">Geri Dön</a>
</form>