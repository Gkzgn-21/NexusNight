@model List<Project2EmailNight.Entities.Message>
@{
    ViewData["Title"] = "Kategori";
}

<div class="cardx p-4">
    <h4 class="mb-3">📁 Kategori Mesajları</h4>

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-warning mb-0">
            Bu kategoride mesaj bulunamadı.
        </div>
    }
    else
    {
        <table class="table table-striped table-bordered">
            <thead>
                <tr>
                    <th>Gönderen</th>
                    <th>Konu</th>
                    <th>Tarih</th>
                    <th>İşlem</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@(string.IsNullOrWhiteSpace(item.SenderName) ? item.SenderEmail : (item.SenderName + " " + item.SenderSurname))</td>
                        <td>
                            <a href="/Message/MessageDetail/@item.MessageId">
                                @item.Subject
                            </a>
                        </td>
                        <td>@item.SendDate.ToString("dd.MM.yyyy HH:mm")</td>
                        <td>
                            <a class="btn btn-sm btn-info" href="/Message/MessageDetail/@item.MessageId">Aç</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>
