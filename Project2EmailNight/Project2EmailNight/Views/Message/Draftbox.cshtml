@model List<Project2EmailNight.Entities.Message>
@{
    ViewData["Title"] = "Taslaklar";
}

<div class="container mt-4">
    <h4>📝 Taslaklar</h4>
    <hr />

    <table class="table table-striped table-bordered">
        <thead class="table-dark">
            <tr>
                <th>Alıcı</th>
                <th>Konu</th>
                <th>Tarih</th>
                <th>İşlem</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.ReceiverEmail</td>
                    <td>@item.Subject</td>
                    <td>@item.SendDate.ToString("dd.MM.yyyy HH:mm")</td>
                    <td>
                        <a href="/Message/EditDraft/@item.MessageId" class="btn btn-sm btn-primary">Düzenle</a>
                        <a href="/Message/Delete/@item.MessageId" class="btn btn-sm btn-danger">Sil</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
