<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - NexusNight</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">

    <style>
        :root {
            --bg: #070814;
            --panel: #0b1024;
            --panel2: #070a16;
            --card: #0e1633;
            --line: rgba(255,255,255,.08);
            --text: #e9edf3;
            --muted: rgba(233,237,243,.72);
            --orange: #f97316;
            --red: #7f1d1d;
            --navy: #1e3a8a;
        }

        body {
            margin: 0;
            background: radial-gradient(1200px 700px at 80% 10%, rgba(249,115,22,.10), transparent 55%), radial-gradient(900px 600px at 20% 30%, rgba(127,29,29,.10), transparent 55%), radial-gradient(900px 600px at 70% 75%, rgba(30,58,138,.18), transparent 55%), var(--bg);
            color: var(--text);
        }

        .app-shell {
            display: flex;
            min-height: 100vh;
        }

        .sidebar {
            width: 290px;
            background: linear-gradient(180deg, rgba(11,16,36,.95), rgba(7,10,22,.95));
            border-right: 1px solid var(--line);
            padding: 18px 14px;
            position: sticky;
            top: 0;
            height: 100vh;
        }

        .brand {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 10px 10px 16px;
            border-bottom: 1px solid var(--line);
            margin-bottom: 14px;
        }

        .logo {
            width: 42px;
            height: 42px;
            border-radius: 14px;
            background: radial-gradient(circle at 25% 25%, rgba(249,115,22,.95), transparent 60%), radial-gradient(circle at 70% 70%, rgba(127,29,29,.95), transparent 55%), linear-gradient(135deg, #111827, #0b1024);
            box-shadow: 0 14px 30px rgba(0,0,0,.45);
            border: 1px solid rgba(249,115,22,.25);
        }

        .brand-title {
            font-weight: 800;
            font-size: 16px;
            letter-spacing: .3px;
        }

        .brand-sub {
            font-size: 11px;
            color: var(--muted);
            margin-top: 4px;
            letter-spacing: .4px;
        }

        .menu-title {
            font-size: 11px;
            color: var(--muted);
            padding: 10px 10px 6px;
            text-transform: uppercase;
            letter-spacing: .6px;
        }

        .menu-item {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 10px 10px;
            border-radius: 14px;
            text-decoration: none;
            color: var(--text);
            margin: 6px 0;
            border: 1px solid transparent;
            background: rgba(255,255,255,.02);
            transition: .15s;
        }

            .menu-item:hover {
                background: rgba(249,115,22,.10);
                border-color: rgba(249,115,22,.18);
            }

            .menu-item.primary {
                background: linear-gradient(135deg, rgba(249,115,22,.22), rgba(127,29,29,.18));
                border-color: rgba(249,115,22,.22);
            }

        .main {
            flex: 1;
            display: flex;
            flex-direction: column;
            min-width: 0;
        }

        .topbar {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 14px 20px;
            border-bottom: 1px solid var(--line);
            background: rgba(7,10,22,.55);
            backdrop-filter: blur(10px);
        }

        .content {
            padding: 22px;
        }

        .table {
            color: var(--text);
        }

            .table thead {
                background: rgba(255,255,255,.06);
            }

        .table-striped tbody tr:nth-of-type(odd) {
            background: rgba(255,255,255,.03);
        }

        .table-bordered {
            border-color: rgba(255,255,255,.10);
        }

        .ql-toolbar.ql-snow, .ql-container.ql-snow {
            border-color: rgba(255,255,255,.12) !important;
        }

        .ql-toolbar.ql-snow {
            background: rgba(255,255,255,.03);
            border-top-left-radius: 14px;
            border-top-right-radius: 14px;
        }

        .ql-container.ql-snow {
            background: rgba(0,0,0,.15);
            border-bottom-left-radius: 14px;
            border-bottom-right-radius: 14px;
            color: var(--text);
            min-height: 220px;
        }

        .ql-editor {
            color: var(--text);
        }
    </style>
</head>

<body>
    <div class="app-shell">

        <aside class="sidebar">
            <div class="brand">
                <div class="logo"></div>
                <div>
                    <div class="brand-title">NexusNight</div>
                    <div class="brand-sub">Mail yönetim paneli</div>
                </div>
            </div>

            <div class="menu-title">GENEL</div>

            <a class="menu-item" href="/Dashboard/Index">🧭 Kontrol Paneli</a>
            <a class="menu-item primary" href="/Message/CreateMessage">➕ Yeni E-Posta</a>

            <a class="menu-item" href="/Message/Inbox">📥 Gelen Kutusu</a>
            <a class="menu-item" href="/Message/Sendbox">📤 Gönderilenler</a>
            <a class="menu-item" href="/Message/Starred">⭐ Yıldızlılar</a>
            <a class="menu-item" href="/Message/Draftbox">📝 Taslaklar</a>
            <a class="menu-item" href="/Message/Trash">🗑 Çöp Kutusu</a>

            <div class="menu-title mt-3">KATEGORİLER</div>
            <a class="menu-item" href="/Message/Category?name=Birincil">🏷️ Birincil</a>
            <a class="menu-item" href="/Message/Category?name=Is">💼 İş</a>
            <a class="menu-item" href="/Message/Category?name=Egitim">🎓 Eğitim</a>

            <div class="menu-title mt-3">HESAP</div>
            <a class="menu-item" href="/Profile/Index">👤 Profil</a>
        </aside>

        <main class="main">
            <header class="topbar">
                <div>
                    <div style="font-weight:700">@ViewData["Title"]</div>
                    <div style="font-size:12px;color:var(--muted)">Lacivert • Koyu Kırmızı • Turuncu</div>
                </div>

                @using System.Security.Claims
                @inject Microsoft.AspNetCore.Identity.UserManager<Project2EmailNight.Entities.AppUser> UserManager

                @{
                    string fullName = "Hesap";

                    if (User?.Identity?.IsAuthenticated ?? false)
                    {
                        var userId = User.FindFirstValue(ClaimTypes.NameIdentifier);
                        if (!string.IsNullOrWhiteSpace(userId))
                        {
                            var u = await UserManager.FindByIdAsync(userId);
                            if (u != null)
                            {
                                fullName = $"{u.Name} {u.Surname}".Trim();
                                if (string.IsNullOrWhiteSpace(fullName))
                                    fullName = u.UserName ?? "Hesap";
                            }
                        }
                    }
                }

                <div class="d-flex align-items-center gap-2">

                    <a class="btn btn-warning d-flex align-items-center gap-2"
                       href="/Message/CreateMessage">
                        <span style="font-size:18px;">+</span>
                        <span>Yeni E-Posta</span>
                    </a>

                    @if (User?.Identity?.IsAuthenticated ?? false)
                    {
                        <div class="dropdown">
                            <button class="btn btn-outline-light dropdown-toggle"
                                    type="button"
                                    data-bs-toggle="dropdown"
                                    aria-expanded="false">
                                @fullName
                            </button>

                            <ul class="dropdown-menu dropdown-menu-end">
                                <li>
                                    <a class="dropdown-item" href="/Profile/Index">Profil</a>
                                </li>
                                <li><hr class="dropdown-divider" /></li>
                                <li>
                                    <a class="dropdown-item text-danger" href="/Login/Logout">Çıkış Yap</a>
                                </li>
                            </ul>
                        </div>
                    }
                </div>
            </header>

            <div class="content">
                @RenderBody()
            </div>
        </main>

    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script src="https://cdn.quilljs.com/1.3.6/quill.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>