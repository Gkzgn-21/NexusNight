@model Project2EmailNight.Models.DashboardViewModel

@{
    ViewData["Title"] = "Kontrol Paneli";
}

<div class="container-fluid p-0">
    <div class="row g-4">
        <div class="col-12 col-lg-3">
            <h2 class="mb-3" style="font-weight:800;">Kontrol Paneli</h2>

            <div class="d-flex flex-column gap-3">

                <div class="stat-circle">
                    <div class="stat-title">Gelen</div>
                    <div class="stat-value">@Model.InboxCount</div>
                </div>

                <div class="stat-circle">
                    <div class="stat-title">Gönderilen</div>
                    <div class="stat-value">@Model.SentCount</div>
                </div>

                <div class="stat-circle">
                    <div class="stat-title">Taslak</div>
                    <div class="stat-value">@Model.DraftCount</div>
                </div>

                <div class="stat-circle">
                    <div class="stat-title">Toplam Gelen</div>
                    <div class="stat-value">@Model.TotalInboxCount</div>
                </div>

            </div>
        </div>

        <div class="col-12 col-lg-9">
            <div class="row g-4">

                <div class="col-12 col-xl-7">
                    <div class="dash-card p-3">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <div style="font-weight:800;font-size:18px;">E-mail Trafiği (7 Gün)</div>
                            <div style="opacity:.75;font-size:13px;">Gelen</div>
                        </div>
                        <div class="chart-box">
                            <canvas id="trafficChart"></canvas>
                        </div>
                    </div>
                </div>

                <div class="col-12 col-xl-5">
                    <div class="dash-card p-3">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <div style="font-weight:800;font-size:18px;">Zaman Dağılımı</div>
                            <div style="opacity:.75;font-size:13px;">(7 gün)</div>
                        </div>
                        <div class="chart-box">
                            <canvas id="timeChart"></canvas>
                        </div>
                    </div>
                </div>
                
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <style>
        .dash-card {
            background: linear-gradient(180deg, rgba(14,22,51,.9), rgba(10,14,29,.85));
            border: 1px solid rgba(255,255,255,.08);
            border-radius: 18px;
            box-shadow: 0 18px 40px rgba(0,0,0,.25);
        }

        .chart-box {
            height: 320px;
            position: relative;
        }

        .stat-circle {
            width: 180px;
            height: 180px;
            border-radius: 999px;
            background: radial-gradient(circle at 30% 30%, rgba(249,115,22,.20), transparent 55%), rgba(249,115,22,.10);
            border: 2px solid rgba(249,115,22,.55);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 8px;
            box-shadow: 0 18px 40px rgba(0,0,0,.25);
        }

        .stat-title {
            opacity: .85;
            font-weight: 700;
            font-size: 14px;
        }

        .stat-value {
            font-size: 44px;
            font-weight: 900;
            line-height: 1;
        }

        @@media (max-width: 991px) {
            .stat-circle {
                width: 100%;
                height: 110px;
                border-radius: 18px;
                align-items: flex-start;
                padding-left: 16px;
            }

            .stat-value {
                font-size: 34px;
            }
        }
    </style>

    <script>
        const labels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.DayLabels));
        const inboxData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.InboxLast7Days));
    </script>

    <script>
        const trafficCtx = document.getElementById('trafficChart');
        new Chart(trafficCtx, {
            type: 'bar',
            data: {
                labels: labels,
                datasets: [{
                    label: 'Gelen',
                    data: inboxData,
                    borderWidth: 0,
                    borderRadius: 10
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: true, labels: { color: '#e9edf3' } }
                },
                scales: {
                    x: { ticks: { color: '#e9edf3' }, grid: { color: 'rgba(255,255,255,.06)' } },
                    y: { ticks: { color: '#e9edf3' }, grid: { color: 'rgba(255,255,255,.06)' }, beginAtZero: true }
                }
            }
        });

        const timeCtx = document.getElementById('timeChart');
        new Chart(timeCtx, {
            type: 'doughnut',
            data: {
                labels: labels,
                datasets: [{
                    data: inboxData,
                    borderWidth: 2
                }]
            },
            options: {
                responsive: true,
                cutout: '70%',
                plugins: {
                    legend: {
                        position: 'top',
                        labels: { color: '#e9edf3' }
                    }
                }
            }
        });
    </script>
}
